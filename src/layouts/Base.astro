---
import '@fontsource/open-sans/300.css';
import '@fontsource/open-sans/400.css';
import '@fontsource/open-sans/600.css';
import '@fontsource/open-sans/700.css';
import '@fontsource/roboto/400.css';
import '@fontsource/roboto/500.css';
import '../styles/global.css';
import praxis from '../data/praxis.yaml';

interface Props {
  title: string;
  description?: string;
  active?: string;
}

const { title, description = 'Fach- und Hausarztpraxis Dres. Ertl in Oberhaching – Allgemeinmedizin, Innere Medizin, Kardiologie und mehr.', active = '' } = Astro.props;

const nav = [
  { label: 'Aktuelles', href: '/', key: 'aktuelles' },
  { label: 'Über Uns', href: '/ueber-uns/', key: 'ueber-uns' },
  { label: 'Praxisteam', href: '/praxisteam/', key: 'praxisteam' },
  { label: 'Leistungen', href: '/leistungen/', key: 'leistungen' },
  { label: 'Termine', href: praxis.terminland, key: 'termine' },
  { label: 'Anfahrt & Kontakt', href: '/kontakt/', key: 'kontakt' },
];
const showBar = praxis.announcement?.sichtbar;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="stylesheet" href="/fa/css/fontawesome.min.css" />
    <link rel="stylesheet" href="/fa/css/solid.min.css" />
    <link rel="stylesheet" href="/fa/css/regular.min.css" />
    <link rel="stylesheet" href="/fa/css/brands.min.css" />
  </head>
  <body class={showBar ? 'has-announcement' : ''}>
    {showBar && (
      <a class="announcement" href={praxis.announcement.url} target="_blank" rel="noopener">
        <span class="mobile-text">Termine können Sie nun online Buchen</span>
        <span class="sh_button">{praxis.announcement.text}</span>
      </a>
    )}

    <div id="page-header">
      <div class="entry-header">
        <a class="logo-img" href="/" title={praxis.name}>
          <img src="/uploads/logo.png" alt={praxis.name} width="550" />
        </a>
      </div>
      <nav id="main-nav">
        <ul id="main-menu">
          {nav.map((item) => (
            <li class={active === item.key ? 'active' : ''}>
              <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined}>{item.label}</a>
            </li>
          ))}
        </ul>
        <button class="mobile-menu-btn" aria-label="Menü öffnen" onclick="document.getElementById('main-nav').classList.toggle('open')">
          <i class="fas fa-chevron-down"></i>
        </button>
        <ul id="mobile-menu">
          {nav.map((item) => (
            <li class={active === item.key ? 'active' : ''}>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    {showBar && (
      <a class="announcement announcement-mobile" href={praxis.announcement.url} target="_blank" rel="noopener">
        <span class="mobile-text">Termine können Sie nun online Buchen</span>
        <span class="sh_button">Termin buchen</span>
      </a>
    )}

    <slot />

    <footer id="page-footer">
      <div class="footer-boxes">
        <div class="iconbox">
          <i class="fas fa-map-marker-alt"></i>
          <div>
            <div class="ib-title">{praxis.adresse.strasse}</div>
            <div class="ib-sub">{praxis.adresse.ort}</div>
          </div>
        </div>
        <div class="iconbox">
          <i class="fas fa-phone-alt"></i>
          <div>
            <div class="ib-title">Telefon</div>
            <div class="ib-sub">{praxis.telefon}</div>
          </div>
        </div>
        <div class="iconbox">
          <i class="far fa-clock"></i>
          <div>
            <div class="ib-title">Sprechstunde</div>
            <div class="ib-sub">{praxis.sprechstundeKurz}</div>
          </div>
        </div>
      </div>
      <div class="footer-disclaimer">{praxis.emailHinweis}</div>
      <hr class="footer-divider" />
      <div class="footer-cols">
        <div>
          <h2>Weitere Informationen</h2>
          <ul>
            <li><a href="/kontakt/">Anfahrt &amp; Kontakt</a></li>
            <li><a href="/datenschutz/">Datenschutz</a></li>
            <li><a href="/impressum/">Impressum</a></li>
          </ul>
        </div>
        <div class="mecum">
          <h2>Wir bilden aus!</h2>
          <img src="/uploads/mecum.png" alt="MeCuM LMU – akademische Lehrpraxis" />
          <div class="caption">akademische Lehrpraxis</div>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="container">© {new Date().getFullYear()} {praxis.name}</div>
      </div>
    </footer>
  </body>
</html>
