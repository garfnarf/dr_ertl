---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import InfoBar from '../components/InfoBar.astro';
import RezeptForm from '../components/RezeptForm.astro';

const eintraege = (await getCollection('aktuelles', (e) => e.data.sichtbar))
  .sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);

const rendered = await Promise.all(
  eintraege.map(async (e) => ({ eintrag: e, Content: (await render(e)).Content }))
);
---
<Base title="Aktuelles – Fach- und Hausarztpraxis Dres. Ertl" active="aktuelles">
  <InfoBar hours={true} />

  {rendered.map(({ eintrag, Content }) => (
    <section class="section" id={eintrag.id}>
      <div class="container">
        <div class="news" data-icon={eintrag.data.listenIcon}>
          <div class="kicker">{eintrag.data.kicker}</div>
          <h4>{eintrag.data.titel}</h4>
          <Content />
          {eintrag.data.rezeptformular && <RezeptForm />}
          {eintrag.data.button && (
            <p style="margin-top: 22px;">
              <a class="btn" href={eintrag.data.button.url} target={eintrag.data.button.url.startsWith('http') ? '_blank' : undefined} rel="noopener">
                {eintrag.data.button.text}
              </a>
            </p>
          )}
        </div>
      </div>
    </section>
  ))}
</Base>

<style is:global>
  /* Markdown-Listen in Aktuelles-Einträgen als Icon-Listen darstellen */
  .news ul { list-style: none; margin-bottom: 15px; }
  .news ul li {
    position: relative;
    padding: 5px 0 5px 32px;
    font-family: var(--font-alt);
    color: var(--text);
  }
  .news ul li::before {
    font-family: 'Font Awesome 5 Free';
    font-weight: 900;
    color: var(--sage);
    position: absolute;
    left: 0;
    top: 5px;
    font-size: 17px;
  }
  .news[data-icon='chevron'] ul li::before { content: '\f054'; }
  .news[data-icon='warnung'] ul li::before { content: '\f071'; }
</style>
