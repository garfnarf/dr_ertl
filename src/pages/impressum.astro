---
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const seite = await getEntry('seiten', 'impressum');
const { Content } = await render(seite!);
---
<Base title="Impressum – Fach- und Hausarztpraxis Dres. Ertl">
  <div class="container legal">
    <h1>{seite!.data.titel}</h1>
    <Content />
  </div>
</Base>
