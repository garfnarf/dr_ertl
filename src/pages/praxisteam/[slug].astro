---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const aerzte = await getCollection('aerzte');
  return aerzte.map((a) => ({ params: { slug: a.id }, props: { arzt: a } }));
}

const { arzt } = Astro.props;
const d = arzt.data;
---
<Base title={`${d.name} – Fach- und Hausarztpraxis Dres. Ertl`} active="praxisteam">
  <div class="cv-titlebar">
    <div class="container">
      <h1>{d.name}</h1>
      <a class="btn" href="/praxisteam/#Arzteteam">Zurück zum Team</a>
    </div>
  </div>

  <div class="container">
    <div class="cv-intro">
      <div class="photo"><img src={d.fotoQuadrat} alt={d.name} /></div>
      <div>
        <div class="subtitle">{d.untertitel}</div>
        <h2>{d.name}</h2>
        <div class="cv-quote">
          <div class="qmark">&ldquo;</div>
          <p>{d.zitat}</p>
          <div class="qmark end">&rdquo;</div>
        </div>
      </div>
    </div>
  </div>

  <div class="container timeline">
    {d.stationen.map((s) => (
      <div class="row">
        <div class="zeitraum">{s.zeitraum}</div>
        <div class="text">{s.text}</div>
      </div>
    ))}
  </div>
</Base>
