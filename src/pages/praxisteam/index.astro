---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TeamCarousel from '../../components/TeamCarousel.astro';

const aerzte = (await getCollection('aerzte')).sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
const team = (await getCollection('team')).sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
---
<Base title="Praxisteam – Fach- und Hausarztpraxis Dres. Ertl" active="praxisteam">
  <TeamCarousel />

  <div class="container" id="Arzteteam">
    <h1 class="page-title" style="margin-top: 55px;">Unser Ärzteteam</h1>
    <div class="aerzte-grid">
      {aerzte.map((a) => (
        <div class="person">
          <div class="photo"><img src={a.data.foto} alt={a.data.name} loading="lazy" /></div>
          <h2>{a.data.name}</h2>
          <a class="btn" href={`/praxisteam/${a.id}/`}>Mehr über mich</a>
          {a.data.beschreibung && <p>{a.data.beschreibung}</p>}
        </div>
      ))}
    </div>

    <h2 class="page-title big-heading" style="font-size: 30px; color: #333;">Unser Praxisteam</h2>
    <div class="team-grid">
      {team.map((t) => (
        <div class="person">
          <div class="photo"><img src={t.data.foto} alt={t.data.name} loading="lazy" /></div>
          <h2>{t.data.name}</h2>
          <p>{t.data.rolle}</p>
        </div>
      ))}
    </div>
  </div>
</Base>
